# ============================================================
# J.A.R.V.I.S — Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ── Identity ─────────────────────────────────────────────────
USER_NAME=Kalpesh
USER_ALIAS=Iron Man

# ── LLM API Keys ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Services API Keys ────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# ── Firebase (optional — for cloud memory sync) ───────────────
FIREBASE_CRED_PATH=

# ── LLM Models ───────────────────────────────────────────────
ONLINE_LLM_MODEL=gemini-2.5-flash
OFFLINE_LLM_MODEL=phi
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free

# ── Ollama Path (Windows default) ────────────────────────────
# OLLAMA_PATH=C:\Users\kalpe\AppData\Local\Programs\Ollama\ollama.exe
# Linux/Mac:
# OLLAMA_PATH=ollama

# ── TTS Settings ─────────────────────────────────────────────
TTS_MODEL=tts_models/en/vctk/vits
TTS_SPEAKER=p228
TTS_SAMPLE_RATE=22050
USE_GPU=auto

# ── STT Settings ─────────────────────────────────────────────
VOSK_MODEL_PATH=C:\Jarvis\body\vosk-model-en-in-0.5
STT_SAMPLE_RATE=16000
STT_BLOCK_SIZE=4000

# ── Memory ───────────────────────────────────────────────────
MAX_HISTORY=20
MEMORY_CONTEXT=6

# ── Defaults ─────────────────────────────────────────────────
DEFAULT_CITY=Pune
DEFAULT_COUNTRY=in
DEFAULT_CRYPTO=bitcoin
DEFAULT_CURRENCY=inr

# ── Startup Mode: ui | voice | both ──────────────────────────
STARTUP_MODE=ui

# ── Debug ────────────────────────────────────────────────────
DEBUG_MODE=false
